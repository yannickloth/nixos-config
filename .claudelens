{
  "version": "1.0",
  "project": "nixos-config",
  "budget": {
    "session": 0.5,
    "daily": 2,
    "weekly": 10,
    "currency": "USD"
  },
  "alerts": {
    "soft_threshold": 0.8,
    "hard_stop": false,
    "notify_on_reset": true
  },
  "model_roi": {
    "enabled": true,
    "preferred_model": "sonnet",
    "nudge_on_overkill": true,
    "nudge_cooldown_min": 10
  }
}